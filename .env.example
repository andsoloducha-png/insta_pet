# Skopiuj ten plik jako .env i wpisz własne wartości.
# Nigdy nie umieszczaj prawdziwych kluczy w .env.example.

AI_PROVIDER=gemini
GEMINI_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_MODELS=gemini-3.5-flash-lite
GEMINI_MAX_RETRIES=3
GEMINI_MAX_OUTPUT_TOKENS=8192
GEMINI_THINKING_LEVEL=minimal
# Każda z poniższych flag dodaje osobne wywołania API. Włącz tylko, gdy potrzebujesz.
GEMINI_EDITOR_ENABLED=false
GEMINI_PROOFREADER_ENABLED=false
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_FALLBACK_MODELS=gemini-3.1-flash-tts-preview
GEMINI_TTS_VOICE=Achird
GEMINI_TTS_MAX_RETRIES=3
GEMINI_API_KEY=tu_wpisz_klucz_gemini
OPENAI_API_KEY=tu_wpisz_klucz_openai
OPENAI_MODEL=gpt-5.6-luna

DOG_NAME=Jogi
DOG_BREED=pudel miniaturowy
DOG_PERSONALITY=pewny siebie urwis: bystry, ciepły, lekko bezczelny i przekonany, że to on ustala zasady

SHEET_URL=https://docs.google.com/spreadsheets/d/TWOJ_ID/edit
# Może to być ścieżka względna albo pełna ścieżka do pliku poza projektem.
GOOGLE_SERVICE_ACCOUNT_FILE=C:/Users/twoja_nazwa/.insta_jog_secrets/service_account.json

# OAuth działa ze zwykłym „Moim dyskiem”. Konto serwisowe wymaga Dysku współdzielonego.
GOOGLE_DRIVE_UPLOAD_ENABLED=false
GOOGLE_DRIVE_OUTPUT_FOLDER_ID=ID_FOLDERU_Z_ADRESU_GOOGLE_DRIVE
GOOGLE_DRIVE_AUTH_MODE=oauth
GOOGLE_DRIVE_OAUTH_CLIENT_FILE=C:/Users/twoja_nazwa/.insta_jog_secrets/google_oauth_client.json
GOOGLE_DRIVE_TOKEN_FILE=C:/Users/twoja_nazwa/.insta_jog_secrets/google_drive_token.json

# Aktywny jest zawsze dokładnie jeden głos: gemini, elevenlabs albo awaryjnie edge.
TTS_PROVIDER=gemini
TTS_VOICE=pl-PL-ZofiaNeural
TTS_FALLBACK_VOICES=pl-PL-MarekNeural
TTS_MAX_RETRIES=2
TTS_PRESET=jogi_playful_soft
TTS_EFFECTS_ENABLED=true
# Pozostaw puste, aby użyć tempa i tonu przypisanego do presetu.
TTS_RATE=
TTS_PITCH=

# Uzupełnij po utworzeniu własnego głosu i przełącz TTS_PROVIDER=elevenlabs.
ELEVENLABS_API_KEY=tu_wpisz_klucz_elevenlabs
ELEVENLABS_VOICE_ID=tu_wpisz_id_glosu
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_MAX_RETRIES=3
ELEVENLABS_STABILITY=0.45
ELEVENLABS_SIMILARITY_BOOST=0.80
ELEVENLABS_STYLE=0.20
ELEVENLABS_SPEAKER_BOOST=true
ELEVENLABS_SPEED=0.96

# Ten podpis działa tak samo z Gemini i ElevenLabs.
TTS_SIGNATURE_LAUGH_ENABLED=true
# Plik jest używany tylko wtedy, gdy powyższa flaga ma wartość true.
TTS_SIGNATURE_LAUGH_FILE=assets/jogi_signature_laugh.wav

VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
