# Skopiuj ten plik jako .env i wpisz własne wartości.
# Nigdy nie umieszczaj prawdziwych kluczy w .env.example.

AI_PROVIDER=gemini
GEMINI_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_MODELS=gemini-3.5-flash-lite
GEMINI_MAX_RETRIES=3
GEMINI_MAX_OUTPUT_TOKENS=4096
GEMINI_THINKING_LEVEL=minimal
GEMINI_API_KEY=tu_wpisz_klucz_gemini
OPENAI_API_KEY=tu_wpisz_klucz_openai
OPENAI_MODEL=gpt-5.6-luna

SHEET_URL=https://docs.google.com/spreadsheets/d/TWOJ_ID/edit
# Może to być ścieżka względna albo pełna ścieżka do pliku poza projektem.
GOOGLE_SERVICE_ACCOUNT_FILE=C:/Users/twoja_nazwa/.insta_jog_secrets/service_account.json

TTS_PROVIDER=edge
TTS_VOICE=pl-PL-ZofiaNeural
TTS_FALLBACK_VOICES=pl-PL-MarekNeural
TTS_MAX_RETRIES=2
TTS_RATE=+8%
TTS_PITCH=+12Hz

VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
